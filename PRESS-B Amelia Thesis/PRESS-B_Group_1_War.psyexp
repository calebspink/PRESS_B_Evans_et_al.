    <Routine name="Extinction">
      <RoutineSettingsComponent name="Extinction" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="Routine for modeling extinction dynamics. Ensure extintinction is properly set via the CSV as it uses the same general logic. " valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Extinction" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="code_ext" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="#Draws the experiment, schedule lights are off&amp;#10;&amp;#10;#Paramaters:&amp;#10;    #win: object&amp;#10;        #The PsychoPy window&amp;#10;    #green_light: object&amp;#10;        #Reinforcement light&amp;#10;    #red_light: object&amp;#10;        #Punishment light&amp;#10;    #button_response: object&amp;#10;        #The response button&amp;#10;    #button_cycle: object&amp;#10;        #The switch button&amp;#10;    #switch_text: object&amp;#10;        #button_cycle label&amp;#10;    #points_display: object&amp;#10;        #Shows how many points the subject has earned&amp;#10;    #lights: list of objects&amp;#10;        #Schedule lights, condensed for readability&amp;#10;&amp;#10;def draw_ext(win, green_light, red_light,&amp;#10;                    button_response, button_cycle,&amp;#10;                    switch_text, points_display, &amp;#10;                    lights):&amp;#10;    win.clearBuffer()&amp;#10;    green_light.draw()&amp;#10;    red_light.draw()&amp;#10;    button_response.draw()&amp;#10;    button_cycle.draw()&amp;#10;    switch_text.draw()&amp;#10;    points_display.draw()&amp;#10;&amp;#10;    if schedule_manager.schedule_lights.strip().upper() == &quot;ON&quot;:&amp;#10;        #Logic for schedule light color and position&amp;#10;        total_lights = len(all_schedules)&amp;#10;&amp;#10;        spacing = 0.15 #How far apart schedule lights are from each other&amp;#10;    &amp;#10;        if total_lights % 2 == 1: #If even&amp;#10;            start_position = -(total_lights // 2) * spacing&amp;#10;        else: #If odd&amp;#10;            start_position = -(total_lights // 2 - 0.5) * spacing&amp;#10;    &amp;#10;        positions = [start_position + i * spacing for i in range(total_lights)]&amp;#10;    &amp;#10;        for i in range(1, total_lights + 1):&amp;#10;            light = light_mapping[i] #uses light index&amp;#10;            light.pos = [positions[i - 1], 0.4]  #Only affects x-coordinate&amp;#10;            light.setFillColor(light_off, 'rgb') #All lights are off for acquisition and extinction phases&amp;#10;            light.draw()&amp;#10;        &amp;#10;    win.flip()&amp;#10;&amp;#10;#Collects space data during extinction&amp;#10;def collect_space_ext():&amp;#10;    thisExp.addData('SessionNumber', 'EXT')&amp;#10;    thisExp.addData('Time', t)&amp;#10;    thisExp.addData('Points', points)&amp;#10;    thisExp.addData('Point Earned', 'N/A') #Is N/A rather than 0 as points cannot be earned if extinction is set correctly&amp;#10;    thisExp.addData('CurrentSchedule', 'EXT') #Schedule is recorded as 'EXT'&amp;#10;    thisExp.addData('Button', 'Blue' if np.array_equal(button_response.fillColor, button_color1) else 'Yellow') #Button color&amp;#10;    thisExp.nextEntry()&amp;#10;    &amp;#10;#Collects tab data&amp;#10;def collect_tab_ext():&amp;#10;    thisExp.addData('SessionNumber', 'EXT')&amp;#10;    thisExp.addData('Time', t)&amp;#10;    thisExp.addData('Points', points)&amp;#10;    thisExp.addData('Point Earned', 'N/A')&amp;#10;    thisExp.addData('CurrentSchedule', 'EXT')&amp;#10;    thisExp.addData('Button', 'Tab')&amp;#10;    thisExp.nextEntry()" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="for (var i, _pj_c = 0, _pj_a = util.range(lights.length), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    i = _pj_a[_pj_c];&amp;#10;    (lights[i].fillColor === light_off);&amp;#10;}&amp;#10;flash_manager = new FlashManager();&amp;#10;start_break = false;&amp;#10;switch_enabled = true;&amp;#10;tab_pressed = false;&amp;#10;schedule_loaded = false;&amp;#10;switch_cod = false;&amp;#10;try {&amp;#10;    schedule_data = schedule_df.loc[(schedule_df[&quot;Schedule_number&quot;] === &quot;EXT&quot;)].copy();&amp;#10;    schedule_manager = new ScheduleManager(safe_float(schedule_data[&quot;Blue_Interval&quot;]), safe_float(schedule_data[&quot;Yellow_Interval&quot;]), safe_float(schedule_data[&quot;Blue_Pun_Interval&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_Interval&quot;]), safe_float(schedule_data[&quot;Blue_Ratio&quot;]), safe_float(schedule_data[&quot;Yellow_Ratio&quot;]), safe_float(schedule_data[&quot;Blue_Pun_Ratio&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_Ratio&quot;]), safe_float(schedule_data[&quot;Blue_Random_Ratio&quot;]), safe_float(schedule_data[&quot;Yellow_Random_Ratio&quot;]), safe_float(schedule_data[&quot;Blue_Pun_Random_Ratio&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_Random_Ratio&quot;]), safe_float(schedule_data[&quot;Blue_Random_Interval&quot;]), safe_float(schedule_data[&quot;Yellow_Random_Interval&quot;]), safe_float(schedule_data[&quot;Blue_Pun_Random_Interval&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_Random_Interval&quot;]), safe_bool(schedule_data[&quot;Blue_FH&quot;].iloc[0]), safe_bool(schedule_data[&quot;Yellow_FH&quot;].iloc[0]), safe_bool(schedule_data[&quot;Blue_Pun_FH&quot;].iloc[0]), safe_bool(schedule_data[&quot;Yellow_Pun_FH&quot;].iloc[0]), safe_float(schedule_data[&quot;Blue_FH_Intervals&quot;]), safe_float(schedule_data[&quot;Yellow_FH_Intervals&quot;]), safe_float(schedule_data[&quot;Blue_Pun_FH_Intervals&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_FH_Intervals&quot;]), safe_string(schedule_data[&quot;Blue_FH_Type&quot;]), safe_string(schedule_data[&quot;Yellow_FH_Type&quot;]), safe_string(schedule_data[&quot;Blue_Pun_FH_Type&quot;]), safe_string(schedule_data[&quot;Yellow_Pun_FH_Type&quot;]), safe_float(schedule_data[&quot;Session_Duration&quot;]), safe_float(schedule_data[&quot;Blue_Mag&quot;]), safe_float(schedule_data[&quot;Yellow_Mag&quot;]), safe_float(schedule_data[&quot;Blue_Pun_Mag&quot;]), safe_float(schedule_data[&quot;Yellow_Pun_Mag&quot;]), safe_float(schedule_data[&quot;Changeover_Delay&quot;]), safe_float(schedule_data[&quot;Blackout_Duration&quot;]), safe_float(schedule_data[&quot;SD_Blue&quot;]), safe_float(schedule_data[&quot;SD_Yellow&quot;]), safe_float(schedule_data[&quot;SD_Blue_Pun&quot;]), safe_float(schedule_data[&quot;SD_Yellow_Pun&quot;]), safe_string(schedule_data[&quot;Schedule_Lights&quot;]));&amp;#10;    schedule_loaded = true;&amp;#10;    routine_active = true;&amp;#10;    extinction = true;&amp;#10;} catch(e) {&amp;#10;    console.log(`Error loading schedule: ${e}`);&amp;#10;    extinction = false;&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="#Turns lights off&amp;#10;for i in range(len(lights)):&amp;#10;     lights[i].fillColor == light_off  &amp;#10;&amp;#10;flash_manager = FlashManager() #'Imports' FlashManager()&amp;#10;&amp;#10;#Initializes Values&amp;#10;start_break = False&amp;#10;switch_enabled = True&amp;#10;tab_pressed = False&amp;#10;schedule_loaded = False &amp;#10;switch_cod = False&amp;#10;&amp;#10;try:&amp;#10;    #Trys to load EXT data&amp;#10;    schedule_data = schedule_df.loc[schedule_df['Schedule_number'] == &quot;EXT&quot;].copy()&amp;#10;    schedule_manager = ScheduleManager(&amp;#10;        safe_float(schedule_data['Blue_Interval']), safe_float(schedule_data['Yellow_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Interval']), safe_float(schedule_data['Yellow_Pun_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Ratio']), safe_float(schedule_data['Yellow_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Ratio']), safe_float(schedule_data['Yellow_Pun_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Random_Ratio']), safe_float(schedule_data['Yellow_Random_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Random_Ratio']), safe_float(schedule_data['Yellow_Pun_Random_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Random_Interval']), safe_float(schedule_data['Yellow_Random_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Random_Interval']), safe_float(schedule_data['Yellow_Pun_Random_Interval']),&amp;#10;        safe_bool(schedule_data['Blue_FH'].iloc[0]), safe_bool(schedule_data['Yellow_FH'].iloc[0]),&amp;#10;        safe_bool(schedule_data['Blue_Pun_FH'].iloc[0]), safe_bool(schedule_data['Yellow_Pun_FH'].iloc[0]),&amp;#10;        safe_float(schedule_data['Blue_FH_Intervals']), safe_float(schedule_data['Yellow_FH_Intervals']),&amp;#10;        safe_float(schedule_data['Blue_Pun_FH_Intervals']), safe_float(schedule_data['Yellow_Pun_FH_Intervals']),&amp;#10;        safe_string(schedule_data['Blue_FH_Type']), safe_string(schedule_data['Yellow_FH_Type']),&amp;#10;        safe_string(schedule_data['Blue_Pun_FH_Type']), safe_string(schedule_data['Yellow_Pun_FH_Type']),&amp;#10;        safe_float(schedule_data['Session_Duration']), safe_float(schedule_data['Blue_Mag']),&amp;#10;        safe_float(schedule_data['Yellow_Mag']), safe_float(schedule_data['Blue_Pun_Mag']),&amp;#10;        safe_float(schedule_data['Yellow_Pun_Mag']), safe_float(schedule_data['Changeover_Delay']),&amp;#10;        safe_float(schedule_data['Blackout_Duration']),&amp;#10;        safe_float(schedule_data['SD_Blue']), safe_float(schedule_data['SD_Yellow']),&amp;#10;        safe_float(schedule_data['SD_Blue_Pun']), safe_float(schedule_data['SD_Yellow_Pun']),&amp;#10;        safe_string(schedule_data['Schedule_Lights'])&amp;#10;       )&amp;#10;    &amp;#10;    #Session in contingent upon the schedule loading&amp;#10;    schedule_loaded = True&amp;#10;    routine_active = True&amp;#10;    extinction = True&amp;#10;&amp;#10;#An error message will be generated if schedule data does not load&amp;#10;except Exception as e:&amp;#10;    print(f&quot;Error loading schedule: {e}&quot;)&amp;#10;    extinction = False&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="while extinction:&amp;#10;    end_keys = event.getKeys(['escape'])&amp;#10;    if 'escape' in end_keys:&amp;#10;        sys.exit()&amp;#10;    #Ends routine if extinction time is up&amp;#10;    if t &gt;= (schedule_manager.session_duration):&amp;#10;        #Progress to high score, no blackout period&amp;#10;        enter_high_score = True&amp;#10;        extinction = False&amp;#10;    &amp;#10;    #If extinction is active&amp;#10;    if routine_active:&amp;#10;        t = routine_clock.getTime() #Current time&amp;#10;        in_changeover_delay = (t - schedule_manager.last_switch_time &lt; schedule_manager.changeover_delay) #COD logic&amp;#10;        keys = event.getKeys(['space', 'tab']) #valid inputs&amp;#10;&amp;#10;        if in_changeover_delay:&amp;#10;            if 'tab' in keys:&amp;#10;                keys.remove('tab') #removes tab presses from log to prevent automatic changes at the conclusion of COD&amp;#10;        tab_pressed = 'tab' in keys #activates COD&amp;#10;&amp;#10;        #Works like the other routines, except values are expected to be set at 0 or 'x' respectively&amp;#10;        if 'space' in keys: &amp;#10;            points, point_earned, press_blue_earn_index, \&amp;#10;            press_blue_loss_index, press_yellow_earn_index, \&amp;#10;            press_yellow_loss_index=\&amp;#10;            handle_space_key(t, schedule_manager, flash_manager, points,&amp;#10;                    button_response, press_blue_earn_index,&amp;#10;                    press_blue_loss_index, press_yellow_earn_index,&amp;#10;                    press_yellow_loss_index)&amp;#10;            points_display.text = f'Points: {points}'&amp;#10;            flash_manager.start_flash('rb', t, button_response)&amp;#10;            collect_space_ext()&amp;#10;        &amp;#10;        #Same as other logic&amp;#10;        if tab_pressed and not in_changeover_delay:&amp;#10;            switch_enabled = handle_tab_key(t, flash_manager,&amp;#10;                                            button_response, schedule_manager)&amp;#10;            collect_tab_ext() &amp;#10;&amp;#10;        if not in_changeover_delay:&amp;#10;            switch_enabled = True &amp;#10;&amp;#10;        flash_manager.update_flashes(t, green_light, red_light,&amp;#10;                                    button_response, button_cycle)&amp;#10;        draw_ext(win, green_light, &amp;#10;                 red_light, button_response, &amp;#10;                 button_cycle, switch_text, &amp;#10;                 points_display, lights)" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;while (extinction) {&amp;#10;    end_keys = psychoJS.eventManager.getKeys([&quot;escape&quot;]);&amp;#10;    if (_pj.in_es6(&quot;escape&quot;, end_keys)) {&amp;#10;        sys.exit();&amp;#10;    }&amp;#10;    if ((t &gt;= schedule_manager.session_duration)) {&amp;#10;        enter_high_score = true;&amp;#10;        extinction = false;&amp;#10;    }&amp;#10;    if (routine_active) {&amp;#10;        t = routine_clock.getTime();&amp;#10;        in_changeover_delay = ((t - schedule_manager.last_switch_time) &lt; schedule_manager.changeover_delay);&amp;#10;        keys = psychoJS.eventManager.getKeys([&quot;space&quot;, &quot;tab&quot;]);&amp;#10;        if (in_changeover_delay) {&amp;#10;            if (_pj.in_es6(&quot;tab&quot;, keys)) {&amp;#10;                keys.remove(&quot;tab&quot;);&amp;#10;            }&amp;#10;        }&amp;#10;        tab_pressed = _pj.in_es6(&quot;tab&quot;, keys);&amp;#10;        if (_pj.in_es6(&quot;space&quot;, keys)) {&amp;#10;            [points, point_earned, press_blue_earn_index, press_blue_loss_index, press_yellow_earn_index, press_yellow_loss_index] = handle_space_key(t, schedule_manager, flash_manager, points, button_response, press_blue_earn_index, press_blue_loss_index, press_yellow_earn_index, press_yellow_loss_index);&amp;#10;            points_display.text = `Points: ${points}`;&amp;#10;            flash_manager.start_flash(&quot;rb&quot;, t, button_response);&amp;#10;            collect_space_ext();&amp;#10;        }&amp;#10;        if ((tab_pressed &amp;&amp; (! in_changeover_delay))) {&amp;#10;            switch_enabled = handle_tab_key(t, flash_manager, button_response, schedule_manager);&amp;#10;            collect_tab_ext();&amp;#10;        }&amp;#10;        if ((! in_changeover_delay)) {&amp;#10;            switch_enabled = true;&amp;#10;        }&amp;#10;        flash_manager.update_flashes(t, green_light, red_light, button_response, button_cycle);&amp;#10;        draw_ext(psychoJS.window, green_light, red_light, button_response, button_cycle, switch_text, points_display, lights);&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="code_ext" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="Enter_High_Score">
      <RoutineSettingsComponent name="Enter_High_Score" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="Scoreboard for experiments without monetary compensation. The top five scores are listed. Users are prompted to enter a three-character identifier. There is no protocol for censorship." valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Enter_High_Score" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="condition" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="high_scores" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="#Objects&amp;#10;score_display = visual.TextStim(win, text='', &amp;#10;pos=(0, 0.05), height=0.05, color=[-1,-1,-1],&amp;#10;colorSpace = 'rgb')&amp;#10;&amp;#10;text_box = visual.TextStim(win, text='',&amp;#10;pos=(0, -0.20), height=0.05, color=[-1,-1,-1],&amp;#10;colorSpace='rgb')&amp;#10;&amp;#10;instruction = visual.TextStim(win, text='', &amp;#10;pos=(0, 0.35), height=0.05)&amp;#10;&amp;#10;whiteboard = visual.Rect(win, &amp;#10;    width=0.8, height=0.5, &amp;#10;    fillColor=[1, 1, 1], lineColor=[0.6,0.6,0.6], &amp;#10;    fillColorSpace='rgb', lineWidth=10, pos=[0, 0])&amp;#10;    &amp;#10;gold_bar = visual.Rect(win, width=0.37, height=0.042,&amp;#10;    fillColor=['gold'], lineColor=[-1,-1,-1],&amp;#10;    fillColorSpace='rgb', lineWidth=1, pos=[0, 0.164])&amp;#10;    &amp;#10;silver_bar = visual.Rect(win, width=0.37, height=0.042,&amp;#10;    fillColor=['silver'], lineColor=[-1,-1,-1],&amp;#10;    fillColorSpace='rgb', lineWidth=1, pos=[0, 0.11])&amp;#10;    &amp;#10;bronze_bar = visual.Rect(win, width=0.37, height=0.042,&amp;#10;    fillColor=[0.6157, 0.0745, -0.4510], lineColor=[-1,-1,-1],&amp;#10;    fillColorSpace='rgb', lineWidth=1, pos=[0, 0.054])&amp;#10;    &amp;#10;#Input text intialized &amp;#10;input_text = ''&amp;#10;&amp;#10;def load_csv(file_path):&amp;#10;    #Checks if the file exists&amp;#10;    if not os.path.exists(file_path):&amp;#10;        #If false, generates DataFrame&amp;#10;        data = pd.DataFrame(columns=['ThreeLetterID', 'HighScore', 'FirstToEarn'])&amp;#10;        #Actually creates the file&amp;#10;        data.to_csv(file_path, index=False)&amp;#10;        print(f&quot;File '{file_path}' created with necessary columns.&quot;)&amp;#10;    else: #Reads file if it does exist&amp;#10;        data = pd.read_csv(file_path)&amp;#10;&amp;#10;    #Check if the required columns exist&amp;#10;    required_columns = ['ThreeLetterID', 'HighScore', 'FirstToEarn']&amp;#10;    for column in required_columns:&amp;#10;        if column not in data.columns:&amp;#10;            raise ValueError(f&quot;The CSV file does not contain a '{column}' column.&quot;)&amp;#10;    return data&amp;#10;&amp;#10;#Draws enter_high_score objects&amp;#10;def draw_scores():&amp;#10;    text_box.setText(input_text)&amp;#10;    whiteboard.draw()&amp;#10;    gold_bar.draw()&amp;#10;    silver_bar.draw()&amp;#10;    bronze_bar.draw()&amp;#10;    text_box.draw()&amp;#10;    score_display.draw()&amp;#10;    instruction.draw()&amp;#10;    &amp;#10;# Load high scores&amp;#10;high_scores_df = load_csv('high_scores.csv')&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;score_display = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;&quot;, &quot;pos&quot;: [0, 0.05], &quot;height&quot;: 0.05, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;colorSpace&quot;: &quot;rgb&quot;});&amp;#10;text_box = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;&quot;, &quot;pos&quot;: [0, (- 0.2)], &quot;height&quot;: 0.05, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;colorSpace&quot;: &quot;rgb&quot;});&amp;#10;instruction = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;&quot;, &quot;pos&quot;: [0, 0.35], &quot;height&quot;: 0.05});&amp;#10;whiteboard = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.8, &quot;height&quot;: 0.5, &quot;fillColor&quot;: [1, 1, 1], &quot;lineColor&quot;: [0.6, 0.6, 0.6], &quot;fillColorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 10, &quot;pos&quot;: [0, 0]});&amp;#10;gold_bar = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.37, &quot;height&quot;: 0.042, &quot;fillColor&quot;: [&quot;gold&quot;], &quot;lineColor&quot;: [(- 1), (- 1), (- 1)], &quot;fillColorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 1, &quot;pos&quot;: [0, 0.164]});&amp;#10;silver_bar = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.37, &quot;height&quot;: 0.042, &quot;fillColor&quot;: [&quot;silver&quot;], &quot;lineColor&quot;: [(- 1), (- 1), (- 1)], &quot;fillColorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 1, &quot;pos&quot;: [0, 0.11]});&amp;#10;bronze_bar = new visual.Rect(psychoJS.window, {&quot;width&quot;: 0.37, &quot;height&quot;: 0.042, &quot;fillColor&quot;: [0.6157, 0.0745, (- 0.451)], &quot;lineColor&quot;: [(- 1), (- 1), (- 1)], &quot;fillColorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 1, &quot;pos&quot;: [0, 0.054]});&amp;#10;input_text = &quot;&quot;;&amp;#10;function load_csv(file_path) {&amp;#10;    var data, required_columns;&amp;#10;    if ((! os.path.exists(file_path))) {&amp;#10;        data = new pd.DataFrame({&quot;columns&quot;: [&quot;ThreeLetterID&quot;, &quot;HighScore&quot;, &quot;FirstToEarn&quot;]});&amp;#10;        data.to_csv(file_path, {&quot;index&quot;: false});&amp;#10;        console.log(`File '${file_path}' created with necessary columns.`);&amp;#10;    } else {&amp;#10;        data = pd.read_csv(file_path);&amp;#10;    }&amp;#10;    required_columns = [&quot;ThreeLetterID&quot;, &quot;HighScore&quot;, &quot;FirstToEarn&quot;];&amp;#10;    for (var column, _pj_c = 0, _pj_a = required_columns, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        column = _pj_a[_pj_c];&amp;#10;        if ((! _pj.in_es6(column, data.columns))) {&amp;#10;            throw new ValueError(`The CSV file does not contain a '${column}' column.`);&amp;#10;        }&amp;#10;    }&amp;#10;    return data;&amp;#10;}&amp;#10;function draw_scores() {&amp;#10;    text_box.setText(input_text);&amp;#10;    whiteboard.draw();&amp;#10;    gold_bar.draw();&amp;#10;    silver_bar.draw();&amp;#10;    bronze_bar.draw();&amp;#10;    text_box.draw();&amp;#10;    score_display.draw();&amp;#10;    instruction.draw();&amp;#10;}&amp;#10;high_scores_df = load_csv(&quot;high_scores.csv&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="enter_high_score = true;&amp;#10;transition_to_goodbye = false;&amp;#10;goodbye = false;&amp;#10;sorted_df = high_scores_df.sort_values({&quot;by&quot;: &quot;HighScore&quot;, &quot;ascending&quot;: false});&amp;#10;sorted_df[&quot;Rank&quot;] = util.range(1, (sorted_df.length + 1));&amp;#10;scores_text = &quot;Top Scores:\n&quot;;&amp;#10;for (var index, _pj_c = 0, _pj_a = sorted_df.head(5).index, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    index = _pj_a[_pj_c];&amp;#10;    scores_text += `${sorted_df[&quot;Rank&quot;].iloc[index]} - ${sorted_df[&quot;ThreeLetterID&quot;].iloc[index]}: ${sorted_df[&quot;HighScore&quot;].iloc[index]}&amp;#10;`;&amp;#10;}&amp;#10;score_display.color = [(- 1), (- 1), (- 1)];&amp;#10;score_display.setText(scores_text);&amp;#10;instruction.setText(&quot;Please type in your name, then hit 'Enter'&quot;);&amp;#10;instruction.draw();&amp;#10;score_display.draw();&amp;#10;psychoJS.window.flip();&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="#Initializes phases&amp;#10;enter_high_score = True&amp;#10;transition_to_goodbye = False&amp;#10;goodbye = False&amp;#10;&amp;#10;#Sorts scores from greatest to least&amp;#10;sorted_df = high_scores_df.sort_values(by='HighScore', ascending=False)&amp;#10;sorted_df['Rank'] = range(1, len(sorted_df) + 1)  # Create rank column&amp;#10;&amp;#10;#Display the top 5 scores&amp;#10;scores_text = ('Top Scores:\n')&amp;#10;for index in sorted_df.head(5).index:&amp;#10;    #Rank, 3 character input, score&amp;#10;    scores_text += f&quot;{sorted_df['Rank'].iloc[index]} - {sorted_df['ThreeLetterID'].iloc[index]}: {sorted_df['HighScore'].iloc[index]}\n&quot;&amp;#10;score_display.color = [-1, -1, -1]&amp;#10;score_display.setText(scores_text)&amp;#10;&amp;#10;#Instructions for the user&amp;#10;instruction.setText(&quot;Please type in your name, then hit 'Enter'&quot;)&amp;#10;&amp;#10;#Draw the instructions and scores to the screen&amp;#10;instruction.draw()&amp;#10;score_display.draw()&amp;#10;win.flip()" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="while enter_high_score:&amp;#10;    end_keys = event.getKeys(['escape'])&amp;#10;    if 'escape' in end_keys:&amp;#10;            sys.exit()&amp;#10;    keys = event.getKeys()&amp;#10;    &amp;#10;    #Prevent users from hitting 'obstructive' keys&amp;#10;    #While I could technically disable more, messing&amp;#10;    #with ctrl, alt, and others related to system function&amp;#10;    #might make an IRB uncomfortable&amp;#10;    banned_keys = ['lshift', 'rshift', 'comma', 'period',&amp;#10;                   'apostrophe', 'slash', 'backslash',&amp;#10;                   'semicolon', 'bracketleft', 'bracketright',&amp;#10;                   'minus', 'equal', 'tab', 'capslock',&amp;#10;                   'quoteleft']&amp;#10;    &amp;#10;    for key in keys:&amp;#10;        if key not in banned_keys:&amp;#10;            if key in ['return', 'enter']:&amp;#10;                if len(input_text) == 3:&amp;#10;                    #Goes to goodbye screen&amp;#10;                    transition_to_goodbye = True&amp;#10;                    enter_high_score = False&amp;#10;            elif key in ['backspace']:&amp;#10;                input_text = input_text[:-1]  #Removes last character&amp;#10;            elif len(input_text) &lt; 3:&amp;#10;                input_text += key.upper() #Three character identifiers are upper case&amp;#10;&amp;#10;    #Update high score input&amp;#10;    draw_scores()&amp;#10;    win.flip()&amp;#10;&amp;#10;#Logic to ease transition&amp;#10;if transition_to_goodbye:&amp;#10;    enter_high_score = False&amp;#10;    goodbye = True&amp;#10;    transition_to_goodbye = False&amp;#10;    break" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="while (enter_high_score) {&amp;#10;    end_keys = psychoJS.eventManager.getKeys([&quot;escape&quot;]);&amp;#10;    if (_pj.in_es6(&quot;escape&quot;, end_keys)) {&amp;#10;        psychoJS.quit();&amp;#10;    }&amp;#10;    keys = psychoJS.eventManager.getKeys();&amp;#10;    banned_keys = [&quot;lshift&quot;, &quot;rshift&quot;, &quot;comma&quot;, &quot;period&quot;, &quot;apostrophe&quot;, &quot;slash&quot;, &quot;backslash&quot;, &quot;semicolon&quot;, &quot;bracketleft&quot;, &quot;bracketright&quot;, &quot;minus&quot;, &quot;equal&quot;, &quot;tab&quot;, &quot;capslock&quot;, &quot;quoteleft&quot;];&amp;#10;    for (var key, _pj_c = 0, _pj_a = keys, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;        key = _pj_a[_pj_c];&amp;#10;        if ((! _pj.in_es6(key, banned_keys))) {&amp;#10;            if (_pj.in_es6(key, [&quot;return&quot;, &quot;enter&quot;])) {&amp;#10;                if ((input_text.length === 3)) {&amp;#10;                    transition_to_goodbye = true;&amp;#10;                    enter_high_score = false;&amp;#10;                    goodbye = true;  // Set it here directly&amp;#10;                }&amp;#10;            } else {&amp;#10;                if (_pj.in_es6(key, [&quot;backspace&quot;])) {&amp;#10;                    input_text = input_text.slice(0, (- 1));&amp;#10;                } else {&amp;#10;                    if ((input_text.length &lt; 3)) {&amp;#10;                        input_text += key.toUpperCase();&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    draw_scores();&amp;#10;    psychoJS.window.flip();&amp;#10;}" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;psychoJS.window.flip();&amp;#10;three_letter_id = input_text;&amp;#10;current_score = points;&amp;#10;new_entry = new pd.DataFrame({&quot;ThreeLetterID&quot;: [three_letter_id], &quot;HighScore&quot;: [current_score], &quot;FirstToEarn&quot;: [((! _pj.in_es6(three_letter_id, high_scores_df[&quot;ThreeLetterID&quot;].values)) ? &quot;True&quot; : &quot;False&quot;)]});&amp;#10;high_scores_df = pd.concat([high_scores_df, new_entry], {&quot;ignore_index&quot;: true});&amp;#10;sorted_df = high_scores_df.sort_values({&quot;by&quot;: &quot;HighScore&quot;, &quot;ascending&quot;: false});&amp;#10;sorted_df[&quot;Rank&quot;] = util.range(1, (sorted_df.length + 1));&amp;#10;function save_csv(file_path, df) {&amp;#10;    df.to_csv(file_path, {&quot;index&quot;: false});&amp;#10;}&amp;#10;save_csv(&quot;high_scores.csv&quot;, sorted_df);&amp;#10;goodbye = true;&amp;#10;psychoJS.window.flip();&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="win.flip()&amp;#10;three_letter_id = input_text&amp;#10;current_score = points  # Assuming `points` holds the participant's current score&amp;#10;&amp;#10;# Add the new score as a new entry even if the participant ID exists&amp;#10;new_entry = pd.DataFrame({&amp;#10;    'ThreeLetterID': [three_letter_id],&amp;#10;    'HighScore': [current_score],&amp;#10;    'FirstToEarn': ['True' if not (three_letter_id in high_scores_df['ThreeLetterID'].values) else 'False']&amp;#10;})&amp;#10;&amp;#10;# Append the new entry to the high_scores_df DataFrame&amp;#10;high_scores_df = pd.concat([high_scores_df, new_entry], ignore_index=True)&amp;#10;&amp;#10;# Sort the updated scores by 'HighScore' in descending order and create ranks&amp;#10;sorted_df = high_scores_df.sort_values(by='HighScore', ascending=False)&amp;#10;sorted_df['Rank'] = range(1, len(sorted_df) + 1)  # Create a new rank column&amp;#10;&amp;#10;# Write the sorted DataFrame back to the CSV file&amp;#10;def save_csv(file_path, df):&amp;#10;    # Ensure the CSV file is saved in sorted order by 'HighScore'&amp;#10;    df.to_csv(file_path, index=False)&amp;#10;&amp;#10;# Save the sorted leaderboard back to the CSV file&amp;#10;save_csv('high_scores.csv', sorted_df)  # Replace with your actual file path&amp;#10;goodbye = True&amp;#10;win.flip()&amp;#10;# Refresh the window to display updated data if needed&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="True" valType="bool" updates="None" name="disabled"/>
        <Param val="high_scores" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="Goodbye">
      <RoutineSettingsComponent name="Goodbye" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
