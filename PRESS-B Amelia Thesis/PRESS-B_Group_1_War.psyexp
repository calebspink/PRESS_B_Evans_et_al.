        <Param val="/*&amp;#10;Space to use PsychoPy's auto-JS converter, never enable this*/&amp;#10;console.log(Object.getPrototypeOf(x));&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
