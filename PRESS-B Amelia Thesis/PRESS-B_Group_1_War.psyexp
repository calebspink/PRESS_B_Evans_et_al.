  <Routines>
    <Routine name="Welcome">
      <RoutineSettingsComponent name="Welcome" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="Presents a welcome message and initializes data collection. The participant begins the experiment contingent upon their press of the 'return' key. Session number, response time, number of points, points earned (as a ternary value), schedule, and button type are collected. This routine is essential for the program to function." valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Welcome" valType="code" updates="None" name="name"/>
        <Param val="False" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="welcome_and_data_collection" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="// Initializations to appease the gods, these do nothing else&amp;#10;let currentLoop;&amp;#10;let frameDur;&amp;#10;let WelcomeClock = [];&amp;#10;let routine_clock = [];&amp;#10;let TrialClock = [];&amp;#10;let GoodbyeClock = [];&amp;#10;let globalClock = [];&amp;#10;let routineTimer = [];&amp;#10;let t = 0;&amp;#10;let frameN = 0;&amp;#10;let continueRoutine = true;&amp;#10;let routineForceEnded = false;&amp;#10;let WelcomeMaxDurationReached = false;&amp;#10;&amp;#10;// --- Added: per-routine MaxDurationReached flags (same pattern as WelcomeMaxDurationReached) ---&amp;#10;let TrialMaxDurationReached = false;&amp;#10;let GoodbyeMaxDurationReached = false;&amp;#10;&amp;#10;// --- Added: MaxDuration values assigned as null inside each RoutineBegin ---&amp;#10;let WelcomeMaxDuration = null;&amp;#10;let TrialMaxDuration = null;&amp;#10;let GoodbyeMaxDuration = null;&amp;#10;&amp;#10;// --- Added: component arrays iterated in RoutineEnd functions ---&amp;#10;let WelcomeComponents = [];&amp;#10;let TrialComponents = [];&amp;#10;let GoodbyeComponents = [];&amp;#10;&amp;#10;// --- Added: loop handler referenced in LoopEnd and TrialRoutineBegin ---&amp;#10;let Selection_type;&amp;#10;&amp;#10;// --- Added: welcome flag set inside WelcomeRoutineBegin ---&amp;#10;let welcome = false;" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="from psychopy import visual, core, event, data&amp;#10;import pandas as pd&amp;#10;&amp;#10;#Initializes points&amp;#10;points = 0&amp;#10;&amp;#10;#Created an Excel spreadsheet&amp;#10;thisExp = data.ExperimentHandler(&amp;#10;    name='PRESS-B_Group 1',&amp;#10;    extraInfo=expInfo,&amp;#10;    dataFileName=f&quot;data/Group_1/PRESS-B_{expInfo['participant']}/PRESS-B_{expInfo['participant']}&quot;&amp;#10;)&amp;#10;#Reads file paths from CSV&amp;#10;schedule_df = pd.read_csv('PRESS-B_1ABA_ABB_Group1_War.csv', na_values=['x']) #Reads CSV&amp;#10;&amp;#10;ding_path = schedule_df['Ding_Path'].iloc[0]&amp;#10;womp_path = schedule_df['Womp_Path'].iloc[0]&amp;#10;keyboard_path = schedule_df['Keyboard_Path'].iloc[0]&amp;#10;&amp;#10;#Initializes data for collection&amp;#10;trialClock = core.Clock()&amp;#10;session_number = []&amp;#10;schedule = []&amp;#10;bluePressTimes = []&amp;#10;yellowPressTimes = []&amp;#10;ctrlPressTimes = []&amp;#10;point_earned = []&amp;#10;responseTimes = []&amp;#10;lastResponseTime = None&amp;#10;&amp;#10;#Tells the user how to begin the experiment&amp;#10;welcome_message = visual.TextStim(win,&amp;#10;    text=&quot;Hello, thank you for participating in the experiment.\nIf you wish to stop participating, hit the 'Escape' key; however, you will not receive sona credit.\nHit 'Enter' when you are ready to begin.&quot;,&amp;#10;    height=0.05, color=[1,1,1], pos=[0, 0])&amp;#10;    &amp;#10;#Shows welcome message, is a function for efficency&amp;#10;def draw_welcome():&amp;#10;    welcome_message.draw()&amp;#10;    win.flip()&amp;#10;    &amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="let schedule_df = [];&amp;#10;let all_schedules = [];&amp;#10;&amp;#10;let csvRaw = psychoJS.serverManager.getResource('PRESS-B_Schedule_Entry.csv');&amp;#10;if (!csvRaw) {&amp;#10;    throw new Error(&quot;CSV failed to load from PsychoJS resources.&quot;);&amp;#10;}&amp;#10;&amp;#10;let csvText;&amp;#10;if (typeof csvRaw === 'string') {&amp;#10;    csvText = csvRaw;&amp;#10;} else {&amp;#10;    csvText = new TextDecoder('utf-8').decode(csvRaw);&amp;#10;}&amp;#10;&amp;#10;const lines = csvText&amp;#10;    .replace(/\r\n/g, '\n')&amp;#10;    .replace(/\r/g, '\n')&amp;#10;    .trim()&amp;#10;    .split('\n')&amp;#10;    .filter(line =&gt; line.trim() !== '');&amp;#10;&amp;#10;const headers = lines[0].split(',').map(h =&gt; h.trim());&amp;#10;&amp;#10;window.schedule_df = lines.slice(1).map(line =&gt; {&amp;#10;    const values = line.split(',');&amp;#10;    let obj = {};&amp;#10;    headers.forEach((h, i) =&gt; {&amp;#10;        let val = values[i] !== undefined ? values[i].trim() : '';&amp;#10;        obj[h] = (val === 'x' || val === '') ? null :&amp;#10;                 (!isNaN(val) &amp;&amp; val !== '' ? Number(val) : val);&amp;#10;    });&amp;#10;    return obj;&amp;#10;});&amp;#10;&amp;#10;window.schedule_df = window.schedule_df.filter(row =&gt;&amp;#10;    row.Schedule_number !== null &amp;&amp;&amp;#10;    row.Schedule_number !== undefined &amp;&amp;&amp;#10;    String(row.Schedule_number).trim() !== ''&amp;#10;);&amp;#10;&amp;#10;window.all_schedules = window.schedule_df&amp;#10;    .map(row =&gt; String(row.Schedule_number).trim())&amp;#10;    .filter(s =&gt; !['EXT', 'ACQ', 'Tutorial', 'Keyboard_Tutorial'].includes(s));&amp;#10;&amp;#10;console.log(&quot;CSV parsed successfully. Schedules found:&quot;, window.all_schedules);&amp;#10;&amp;#10;// Welcome message&amp;#10;window.welcome_message = new visual.TextStim({&amp;#10;    win: psychoJS.window,&amp;#10;    name: 'welcome_message',&amp;#10;    text: &quot;Hello, thank you for participating in the experiment.\n&quot; +&amp;#10;          &quot;If you wish to stop participating, hit the 'Escape' key; however, you will not receive sona credit.\n&quot; +&amp;#10;          &quot;Hit 'Enter' when you are ready to begin.&quot;,&amp;#10;    height: 0.05,&amp;#10;    color: new util.Color([1, 1, 1]),&amp;#10;    pos: [0, 0],&amp;#10;    units: 'height'&amp;#10;});" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="psychoJS.eventManager.clearEvents();&amp;#10;welcome = true;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="#Initializes routine boolean&amp;#10;welcome = True" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="while welcome:&amp;#10;    end_keys = event.getKeys(['escape'])&amp;#10;    if 'escape' in end_keys:&amp;#10;        sys.exit()&amp;#10;    keys = event.getKeys(['return']) #If enter is pressed&amp;#10;    draw_welcome()&amp;#10;    if 'return' in keys: &amp;#10;        welcome = False #Ends routine&amp;#10;        win.flip()" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="// Schedule.Event is used to nullify PsychoJS&amp;#10;// default settings. This is important for ease of &amp;#10;// use.&amp;#10;&amp;#10;continueRoutine = true;&amp;#10;&amp;#10;window.welcome_message.draw();&amp;#10;&amp;#10;// Enables the reading of keys&amp;#10;window.read_keys = psychoJS.eventManager.getKeys();&amp;#10;&amp;#10;// Allow the user to withdraw consent &amp;#10;if (window.read_keys.includes(&quot;escape&quot;)) {&amp;#10;    psychoJS.quit({ message: &quot;Experiment ended by participant.&quot; });&amp;#10;}&amp;#10;&amp;#10;if (window.read_keys.includes(&quot;Tab&quot;)) {&amp;#10;    console.log(&quot;PsychoJS can read tab&quot;);&amp;#10;}&amp;#10;&amp;#10;if (window.read_keys.includes(&quot;ctrl&quot;)) {&amp;#10;    console.log(&quot;PsychoJS can read ctrl&quot;);&amp;#10;}&amp;#10;&amp;#10;if (window.read_keys.includes(&quot;shift&quot;)) {&amp;#10;    console.log(&quot;PsychoJS can read shift&quot;);&amp;#10;}&amp;#10;&amp;#10;if (window.read_keys.includes(&quot;s&quot;)) {&amp;#10;    console.log(&quot;PsychoJS can read s&quot;);&amp;#10;}&amp;#10;&amp;#10;// Procede to next routine&amp;#10;&amp;#10;if (window.read_keys.includes(&quot;return&quot;)) {&amp;#10;    console.log(&quot;Welcome ended with enter, huzzah!&quot;)&amp;#10;    return Scheduler.Event.NEXT;  &amp;#10;}&amp;#10;&amp;#10;return Scheduler.Event.FLIP_REPEAT;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="console.log(&quot;Exited exit from welcome recorded&quot;);&amp;#10;window.welcome_message.setAutoDraw(false);" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="welcome_and_data_collection" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="Keyboard_Tutorial">
      <RoutineSettingsComponent name="Keyboard_Tutorial" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="" valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Keyboard_Tutorial" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="code_keyboard_tut" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="from psychopy import core, event, visual, monitors&amp;#10;import numpy as np&amp;#10;import random&amp;#10;import time&amp;#10;import pandas as pd&amp;#10;from enum import Enum&amp;#10;&amp;#10;#Initialize tutorial points&amp;#10;blue_points = 0&amp;#10;yellow_points = 0&amp;#10;&amp;#10;try:&amp;#10;    if keyboard_path is not None:&amp;#10;        keyboard_image = visual.ImageStim(win=win,&amp;#10;            name='Keyboard_pic', image=keyboard_path,&amp;#10;            mask=None, anchor='center', ori=0, pos=(0, 0.375),&amp;#10;            size=(0.3,0.15),  color=[1,1,1], colorSpace='rgb',&amp;#10;            opacity=None, flipHoriz=False, flipVert=False,&amp;#10;            interpolate=True, depth=0)&amp;#10;        print(&quot;Context image exists&quot;)&amp;#10;    else:&amp;#10;        context_image = None&amp;#10;        print(&quot;Keyboard does not exist&quot;)&amp;#10;except Exception as e:&amp;#10;   print(f&quot;Error with Keyboard: {e}&quot;)&amp;#10;   keyboard_image = None&amp;#10;&amp;#10;#Initializes current_schedule&amp;#10;current_schedule = None&amp;#10;&amp;#10;&amp;#10;#Draws the experiment, schedule lights are off&amp;#10;&amp;#10;#Paramaters:&amp;#10;    #win: object&amp;#10;        #The PsychoPy window&amp;#10;    #green_light: object&amp;#10;        #Reinforcement light&amp;#10;    #red_light: object&amp;#10;        #Punishment light&amp;#10;    #button_response: object&amp;#10;        #The response button&amp;#10;    #button_cycle: object&amp;#10;        #The switch button&amp;#10;    #switch_text: object&amp;#10;        #button_cycle label&amp;#10;    #points_display: object&amp;#10;        #Shows how many points the subject has earned&amp;#10;    #lights: list of objects&amp;#10;        #Schedule lights, condensed for my own sanity&amp;#10;&amp;#10;#Draws all objects for acquisition&amp;#10;def draw_main_keyboard(win, green_light, red_light,&amp;#10;                    button_response, button_cycle,&amp;#10;                    switch_text, points_display, &amp;#10;                    lights, schedule_manager):&amp;#10;    win.clearBuffer()&amp;#10;    green_light.draw()&amp;#10;    red_light.draw()&amp;#10;    button_response.draw()&amp;#10;    button_cycle.draw()&amp;#10;    switch_text.draw()&amp;#10;    points_display.draw()&amp;#10;    if keyboard_image is not None:&amp;#10;        keyboard_image.draw()&amp;#10;    win.flip()&amp;#10;    &amp;#10;def handle_space_tutorial(t, schedule_manager, flash_manager, points,&amp;#10;                          button_response, press_blue_earn_index, &amp;#10;                          press_yellow_earn_index, blue_points, yellow_points):&amp;#10;    # Check for earning points, depends upon schedule data&amp;#10;    if (button_response.fillColor == [-1, -1, 1]).all(): # Blue button&amp;#10;        # Earning Logic&amp;#10;        if schedule_manager.blue_i &gt; 0 and schedule_manager.blue_i != float('inf'): # Interval schedule (time-based)&amp;#10;            if t &gt;= schedule_manager.next_blue_earn_time:&amp;#10;                if blue_points &lt;= 9: #Ensures only 10 blue_points can be earned&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    schedule_manager.blue_fh_index += 1&amp;#10;                    schedule_manager.next_blue_earn_time = schedule_manager.calculate_next_blue_earn_time(button_response)&amp;#10;                    flash_manager.start_flash('gl', t) # Start green light flash&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.blue_r &gt; 0 and schedule_manager.blue_r != float('inf'): # Ratio schedule (press-based)&amp;#10;            press_blue_earn_index += 1&amp;#10;            if press_blue_earn_index &gt;= round(schedule_manager.calculate_next_press_earn_requirement(button_response)):&amp;#10;                if blue_points &lt;= 9:&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    press_blue_earn_index = 0&amp;#10;                    schedule_manager.blue_fh_index += 1&amp;#10;                    flash_manager.start_flash('gl', t) # Start green light flash&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.blue_random_r &gt; 0:&amp;#10;            blue_earn_random_value = random.random()&amp;#10;            if schedule_manager.blue_random_r_chance &gt;= blue_earn_random_value:&amp;#10;                if blue_points &lt;= 9:&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.blue_random_i &gt; 0:&amp;#10;            if schedule_manager.blue_random_i_chance &gt; schedule_manager.blue_interval_earn_value:&amp;#10;                if blue_points &lt;= 9:&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    schedule_manager.blue_interval_earn_value = 1&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;                    current_sound = play_sound(ding)&amp;#10;&amp;#10;    # Handle Yellow Button&amp;#10;    elif (button_response.fillColor == [1, 1, -1]).all(): # Yellow button&amp;#10;        # Earning Logic&amp;#10;        if schedule_manager.yellow_i &gt; 0 and schedule_manager.yellow_i != float('inf'): # Interval schedule (time-based)&amp;#10;            if t &gt;= schedule_manager.next_yellow_earn_time:&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    schedule_manager.yellow_fh_index += 1&amp;#10;                    schedule_manager.next_yellow_earn_time = schedule_manager.calculate_next_yellow_earn_time(button_response)&amp;#10;                    flash_manager.start_flash('gl', t) # Start green light flash&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.yellow_r &gt; 0 and schedule_manager.yellow_r != float('inf'): # Ratio schedule (press-based)&amp;#10;            press_yellow_earn_index += 1&amp;#10;            if press_yellow_earn_index &gt;= round(schedule_manager.calculate_next_press_earn_requirement(button_response)):&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    press_yellow_earn_index = 0&amp;#10;                    schedule_manager.yellow_fh_index += 1&amp;#10;                    flash_manager.start_flash('gl', t) # Start green light flash&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.yellow_random_r &gt; 0:&amp;#10;            yellow_earn_random_value = random.random()&amp;#10;            if schedule_manager.yellow_random_r_chance &gt;= yellow_earn_random_value:&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;                    current_sound = play_sound(ding)&amp;#10;        elif schedule_manager.yellow_random_i &gt; 0:&amp;#10;            if schedule_manager.yellow_random_i_chance &gt; schedule_manager.yellow_interval_earn_value:&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    schedule_manager.yellow_interval_earn_value = 1&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;                    current_sound = play_sound(ding)&amp;#10;&amp;#10;    return (points, press_blue_earn_index,&amp;#10;            press_yellow_earn_index,&amp;#10;            blue_points, yellow_points)&amp;#10;&amp;#10;#Collects data from 'space' presses for the acquisition phase&amp;#10;def collect_space_keyboard():&amp;#10;    thisExp.addData('SessionNumber', 'Keyboard Tutorial')&amp;#10;    thisExp.addData('Time', t)&amp;#10;    thisExp.addData('Points', points)&amp;#10;    thisExp.addData('Point Earned', point_earned)&amp;#10;    thisExp.addData('CurrentSchedule', 'ACQ')&amp;#10;    thisExp.addData('Button', 'Blue' if np.array_equal(button_response.fillColor, button_color1) else 'Yellow')&amp;#10;    thisExp.nextEntry()&amp;#10;&amp;#10;#collects data for 'tab' presses&amp;#10;def collect_tab_keyboard():&amp;#10;    thisExp.addData('SessionNumber', 'Keyboard Tutorial')&amp;#10;    thisExp.addData('Time', t)&amp;#10;    thisExp.addData('Points', points)&amp;#10;    thisExp.addData('Point Earned', 'N/A')&amp;#10;    thisExp.addData('CurrentSchedule', 'ACQ')&amp;#10;    thisExp.addData('Button', 'Tab')&amp;#10;    thisExp.nextEntry()" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="blue_points = 0;&amp;#10;yellow_points = 0;&amp;#10;try {&amp;#10;    if ((keyboard_path !== null)) {&amp;#10;        keyboard_image = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: &quot;Keyboard_pic&quot;, &quot;image&quot;: keyboard_path, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0, &quot;pos&quot;: [0, 0.375], &quot;size&quot;: [0.3, 0.15], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: null, &quot;flipHoriz&quot;: false, &quot;flipVert&quot;: false, &quot;interpolate&quot;: true, &quot;depth&quot;: 0});&amp;#10;        console.log(&quot;Context image exists&quot;);&amp;#10;    } else {&amp;#10;        context_image = null;&amp;#10;        console.log(&quot;Keyboard does not exist&quot;);&amp;#10;    }&amp;#10;} catch(e) {&amp;#10;    console.log(`Error with Keyboard: ${e}`);&amp;#10;    keyboard_image = null;&amp;#10;}&amp;#10;current_schedule = null;&amp;#10;function draw_main_keyboard(win, green_light, red_light, button_response, button_cycle, switch_text, points_display, lights, schedule_manager) {&amp;#10;    psychoJS.window.clearBuffer();&amp;#10;    green_light.draw();&amp;#10;    red_light.draw();&amp;#10;    button_response.draw();&amp;#10;    button_cycle.draw();&amp;#10;    switch_text.draw();&amp;#10;    points_display.draw();&amp;#10;    if ((keyboard_image !== null)) {&amp;#10;        keyboard_image.draw();&amp;#10;    }&amp;#10;    psychoJS.window.flip();&amp;#10;}&amp;#10;function handle_space_tutorial(t, schedule_manager, flash_manager, points, button_response, press_blue_earn_index, press_yellow_earn_index, blue_points, yellow_points) {&amp;#10;    var blue_earn_random_value, current_sound, yellow_earn_random_value;&amp;#10;    if ((button_response.fillColor === [(- 1), (- 1), 1]).all()) {&amp;#10;        if (((schedule_manager.blue_i &gt; 0) &amp;&amp; (schedule_manager.blue_i !== Number.parseFloat(&quot;inf&quot;)))) {&amp;#10;            if ((t &gt;= schedule_manager.next_blue_earn_time)) {&amp;#10;                if ((blue_points &lt;= 9)) {&amp;#10;                    blue_points += 1;&amp;#10;                    points += Number.parseInt(schedule_manager.blue_mag);&amp;#10;                    schedule_manager.blue_fh_index += 1;&amp;#10;                    schedule_manager.next_blue_earn_time = schedule_manager.calculate_next_blue_earn_time(button_response);&amp;#10;                    flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                    current_sound = play_sound(ding);&amp;#10;                }&amp;#10;            }&amp;#10;        } else {&amp;#10;            if (((schedule_manager.blue_r &gt; 0) &amp;&amp; (schedule_manager.blue_r !== Number.parseFloat(&quot;inf&quot;)))) {&amp;#10;                press_blue_earn_index += 1;&amp;#10;                if ((press_blue_earn_index &gt;= util.round(schedule_manager.calculate_next_press_earn_requirement(button_response)))) {&amp;#10;                    if ((blue_points &lt;= 9)) {&amp;#10;                        blue_points += 1;&amp;#10;                        points += Number.parseInt(schedule_manager.blue_mag);&amp;#10;                        press_blue_earn_index = 0;&amp;#10;                        schedule_manager.blue_fh_index += 1;&amp;#10;                        flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                        current_sound = play_sound(ding);&amp;#10;                    }&amp;#10;                }&amp;#10;            } else {&amp;#10;                if ((schedule_manager.blue_random_r &gt; 0)) {&amp;#10;                    blue_earn_random_value = Math.random.random();&amp;#10;                    if ((schedule_manager.blue_random_r_chance &gt;= blue_earn_random_value)) {&amp;#10;                        if ((blue_points &lt;= 9)) {&amp;#10;                            blue_points += 1;&amp;#10;                            points += Number.parseInt(schedule_manager.blue_mag);&amp;#10;                            flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                            current_sound = play_sound(ding);&amp;#10;                        }&amp;#10;                    }&amp;#10;                } else {&amp;#10;                    if ((schedule_manager.blue_random_i &gt; 0)) {&amp;#10;                        if ((schedule_manager.blue_random_i_chance &gt; schedule_manager.blue_interval_earn_value)) {&amp;#10;                            if ((blue_points &lt;= 9)) {&amp;#10;                                blue_points += 1;&amp;#10;                                points += Number.parseInt(schedule_manager.blue_mag);&amp;#10;                                schedule_manager.blue_interval_earn_value = 1;&amp;#10;                                flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                                current_sound = play_sound(ding);&amp;#10;                            }&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    } else {&amp;#10;        if ((button_response.fillColor === [1, 1, (- 1)]).all()) {&amp;#10;            if (((schedule_manager.yellow_i &gt; 0) &amp;&amp; (schedule_manager.yellow_i !== Number.parseFloat(&quot;inf&quot;)))) {&amp;#10;                if ((t &gt;= schedule_manager.next_yellow_earn_time)) {&amp;#10;                    if ((yellow_points &lt;= 9)) {&amp;#10;                        yellow_points += 1;&amp;#10;                        points += Number.parseInt(schedule_manager.yellow_mag);&amp;#10;                        schedule_manager.yellow_fh_index += 1;&amp;#10;                        schedule_manager.next_yellow_earn_time = schedule_manager.calculate_next_yellow_earn_time(button_response);&amp;#10;                        flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                        current_sound = play_sound(ding);&amp;#10;                    }&amp;#10;                }&amp;#10;            } else {&amp;#10;                if (((schedule_manager.yellow_r &gt; 0) &amp;&amp; (schedule_manager.yellow_r !== Number.parseFloat(&quot;inf&quot;)))) {&amp;#10;                    press_yellow_earn_index += 1;&amp;#10;                    if ((press_yellow_earn_index &gt;= util.round(schedule_manager.calculate_next_press_earn_requirement(button_response)))) {&amp;#10;                        if ((yellow_points &lt;= 9)) {&amp;#10;                            yellow_points += 1;&amp;#10;                            points += Number.parseInt(schedule_manager.yellow_mag);&amp;#10;                            press_yellow_earn_index = 0;&amp;#10;                            schedule_manager.yellow_fh_index += 1;&amp;#10;                            flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                            current_sound = play_sound(ding);&amp;#10;                        }&amp;#10;                    }&amp;#10;                } else {&amp;#10;                    if ((schedule_manager.yellow_random_r &gt; 0)) {&amp;#10;                        yellow_earn_random_value = Math.random.random();&amp;#10;                        if ((schedule_manager.yellow_random_r_chance &gt;= yellow_earn_random_value)) {&amp;#10;                            if ((yellow_points &lt;= 9)) {&amp;#10;                                yellow_points += 1;&amp;#10;                                points += Number.parseInt(schedule_manager.yellow_mag);&amp;#10;                                flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                                current_sound = play_sound(ding);&amp;#10;                            }&amp;#10;                        }&amp;#10;                    } else {&amp;#10;                        if ((schedule_manager.yellow_random_i &gt; 0)) {&amp;#10;                            if ((schedule_manager.yellow_random_i_chance &gt; schedule_manager.yellow_interval_earn_value)) {&amp;#10;                                if ((yellow_points &lt;= 9)) {&amp;#10;                                    yellow_points += 1;&amp;#10;                                    points += Number.parseInt(schedule_manager.yellow_mag);&amp;#10;                                    schedule_manager.yellow_interval_earn_value = 1;&amp;#10;                                    flash_manager.start_flash(&quot;gl&quot;, t);&amp;#10;                                    current_sound = play_sound(ding);&amp;#10;                                }&amp;#10;                            }&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    return [points, press_blue_earn_index, press_yellow_earn_index, blue_points, yellow_points];&amp;#10;}&amp;#10;function collect_space_keyboard() {&amp;#10;    psychoJS.experiment.addData(&quot;SessionNumber&quot;, &quot;Keyboard Tutorial&quot;);&amp;#10;    psychoJS.experiment.addData(&quot;Time&quot;, t);&amp;#10;    psychoJS.experiment.addData(&quot;Points&quot;, points);&amp;#10;    psychoJS.experiment.addData(&quot;Point Earned&quot;, point_earned);&amp;#10;    psychoJS.experiment.addData(&quot;CurrentSchedule&quot;, &quot;ACQ&quot;);&amp;#10;    psychoJS.experiment.addData(&quot;Button&quot;, (np.array_equal(button_response.fillColor, button_color1) ? &quot;Blue&quot; : &quot;Yellow&quot;));&amp;#10;    psychoJS.experiment.nextEntry();&amp;#10;}&amp;#10;function collect_tab_keyboard() {&amp;#10;    psychoJS.experiment.addData(&quot;SessionNumber&quot;, &quot;Keyboard Tutorial&quot;);&amp;#10;    psychoJS.experiment.addData(&quot;Time&quot;, t);&amp;#10;    psychoJS.experiment.addData(&quot;Points&quot;, points);&amp;#10;    psychoJS.experiment.addData(&quot;Point Earned&quot;, &quot;N/A&quot;);&amp;#10;    psychoJS.experiment.addData(&quot;CurrentSchedule&quot;, &quot;ACQ&quot;);&amp;#10;    psychoJS.experiment.addData(&quot;Button&quot;, &quot;Tab&quot;);&amp;#10;    psychoJS.experiment.nextEntry();&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="flash_manager = FlashManager() #&quot;Imports&quot; FlashManager class&amp;#10;routine_clock = core.Clock() #Timer mechanism&amp;#10;&amp;#10;#Initializes listed components&amp;#10;start_break = False&amp;#10;switch_enabled = True&amp;#10;tab_pressed = False&amp;#10;switch_cod = False&amp;#10;schedule_loaded = False  #Flag to ensure the schedule is fully loaded&amp;#10;blackout_period =  False&amp;#10;blackout_timer = None&amp;#10;blackout_start_time = None&amp;#10;&amp;#10;#Initializes proc values as impossible&amp;#10;blue_earn_proc_value = 1&amp;#10;blue_loss_proc_value = 1&amp;#10;yellow_earn_proc_value = 1&amp;#10;yellow_loss_proc_value = 1&amp;#10;&amp;#10;#resets press indices&amp;#10;press_blue_earn_index = 0&amp;#10;press_blue_loss_index = 0&amp;#10;press_yellow_earn_index = 0&amp;#10;press_yellow_loss_index = 0&amp;#10;&amp;#10;#Resets FH indicies&amp;#10;blue_fh_index = 0&amp;#10;yellow_fh_index = 0 &amp;#10;blue_pun_fh_index = 0 &amp;#10;yellow_pun_fh_index = 0&amp;#10;&amp;#10;try:&amp;#10;    #Reads data from 'ACQ' schedule from the CSV&amp;#10;    schedule_data = schedule_df.loc[schedule_df['Schedule_number'] == &quot;Keyboard_Tutorial&quot;].copy()&amp;#10;    schedule_manager = ScheduleManager(&amp;#10;        safe_float(schedule_data['Blue_Interval']), safe_float(schedule_data['Yellow_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Interval']), safe_float(schedule_data['Yellow_Pun_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Ratio']), safe_float(schedule_data['Yellow_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Ratio']), safe_float(schedule_data['Yellow_Pun_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Random_Ratio']), safe_float(schedule_data['Yellow_Random_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Random_Ratio']), safe_float(schedule_data['Yellow_Pun_Random_Ratio']),&amp;#10;        safe_float(schedule_data['Blue_Random_Interval']), safe_float(schedule_data['Yellow_Random_Interval']),&amp;#10;        safe_float(schedule_data['Blue_Pun_Random_Interval']), safe_float(schedule_data['Yellow_Pun_Random_Interval']),&amp;#10;        safe_bool(schedule_data['Blue_FH'].iloc[0]), safe_bool(schedule_data['Yellow_FH'].iloc[0]),&amp;#10;        safe_bool(schedule_data['Blue_Pun_FH'].iloc[0]), safe_bool(schedule_data['Yellow_Pun_FH'].iloc[0]),&amp;#10;        safe_float(schedule_data['Blue_FH_Intervals']), safe_float(schedule_data['Yellow_FH_Intervals']),&amp;#10;        safe_float(schedule_data['Blue_Pun_FH_Intervals']), safe_float(schedule_data['Yellow_Pun_FH_Intervals']),&amp;#10;        safe_string(schedule_data['Blue_FH_Type']), safe_string(schedule_data['Yellow_FH_Type']),&amp;#10;        safe_string(schedule_data['Blue_Pun_FH_Type']), safe_string(schedule_data['Yellow_Pun_FH_Type']),&amp;#10;        safe_float(schedule_data['Session_Duration']), safe_float(schedule_data['Blue_Mag']),&amp;#10;        safe_float(schedule_data['Yellow_Mag']), safe_float(schedule_data['Blue_Pun_Mag']),&amp;#10;        safe_float(schedule_data['Yellow_Pun_Mag']), safe_float(schedule_data['Changeover_Delay']),&amp;#10;        safe_float(schedule_data['Blackout_Duration']),&amp;#10;        safe_string(schedule_data['Blue_Distribution']), safe_string(schedule_data['Yellow_Distribution']),&amp;#10;        safe_string(schedule_data['Blue_Pun_Distribution']), safe_string(schedule_data['Yellow_Pun_Distribution']),&amp;#10;        safe_float(schedule_data['SD_Blue']), safe_float(schedule_data['SD_Yellow']),&amp;#10;        safe_float(schedule_data['SD_Blue_Pun']), safe_float(schedule_data['SD_Yellow_Pun']),&amp;#10;        safe_string(schedule_data['Schedule_Lights'])&amp;#10;        )&amp;#10;    &amp;#10;    #If data is read, the routine will proceed&amp;#10;    schedule_loaded = True&amp;#10;    schedule_manager.generate_fleshler_hoffman_list()&amp;#10;    routine_active = True&amp;#10;    keyboard_tutorial = True&amp;#10;    &amp;#10;#Routine will not run if data is incomplete&amp;#10;except Exception as e:&amp;#10;    print(f&quot;Error loading schedule: {e}&quot;)&amp;#10;    keyboard_tutorial = False  &amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="#Main loop&amp;#10;while keyboard_tutorial:&amp;#10;    end_keys = event.getKeys(['escape'])&amp;#10;    if 'escape' in end_keys:&amp;#10;            sys.exit()&amp;#10;    t = routine_clock.getTime() # Get current time&amp;#10;    &amp;#10;    # Check if session should end&amp;#10;    if t &gt;= schedule_manager.session_duration and ((blue_points &gt;= 10) and (yellow_points &gt;= 10)):&amp;#10;        blackout_period = True&amp;#10;        routine_active = False&amp;#10;&amp;#10;    # If the session is active, execute schedule logic&amp;#10;    if routine_active:&amp;#10;        schedule_manager.generate_one_second_interval()&amp;#10;        in_changeover_delay = (t - schedule_manager.last_switch_time &lt; schedule_manager.changeover_delay)&amp;#10;        keys = event.getKeys(['space', 'tab'])&amp;#10;&amp;#10;        # Remove tab presses if within changeover delay&amp;#10;        if in_changeover_delay and 'tab' in keys:&amp;#10;            keys.remove('tab')&amp;#10;            collect_tab_keyboard()&amp;#10;        tab_pressed = 'tab' in keys&amp;#10;&amp;#10;        # Handle space key logic&amp;#10;        if 'space' in keys and in_changeover_delay == False:&amp;#10;            points, press_blue_earn_index, \&amp;#10;            press_yellow_earn_index, \&amp;#10;            blue_points, yellow_points =\&amp;#10;            handle_space_tutorial(t, schedule_manager, flash_manager, &amp;#10;                                  points, button_response,&amp;#10;                                  press_blue_earn_index,&amp;#10;                                  press_yellow_earn_index, &amp;#10;                                  blue_points, yellow_points)&amp;#10;            points_display.text = f'Points: {points}'&amp;#10;            flash_manager.start_flash('rb', t)&amp;#10;            collect_space_keyboard()&amp;#10;&amp;#10;        # Handle tab key logic&amp;#10;        if tab_pressed and not in_changeover_delay:&amp;#10;            switch_enabled = handle_tab_key(t, flash_manager, button_response, schedule_manager)&amp;#10;            collect_tab_keyboard()&amp;#10;&amp;#10;        # Update flashes and draw interface&amp;#10;        flash_manager.update_flashes(t, green_light, red_light, button_response, button_cycle)&amp;#10;        draw_main_keyboard(win, green_light, red_light, button_response, button_cycle, switch_text, points_display, lights, schedule_manager)&amp;#10;&amp;#10;    # Handle blackout period&amp;#10;    elif blackout_period:&amp;#10;        keys = event.getKeys(['return'])&amp;#10;        if blackout_timer is None:&amp;#10;            blackout_timer = core.CountdownTimer(schedule_manager.blackout_duration + 1)&amp;#10;            blackout_start_time = core.getTime()&amp;#10;&amp;#10;        elapsed_time = core.getTime() - blackout_start_time&amp;#10;        remaining_time = max(0, int(schedule_manager.blackout_duration + 1 - elapsed_time))&amp;#10;        timer_text.text = f&quot;Time Remaining: {remaining_time}&quot; if remaining_time &gt;= 1 else &quot;Hit 'enter' to continue&quot;&amp;#10;        draw_break(win, green_light_bo, red_light_bo, timer_text, points_display, response_bo, button_cycle_bo)&amp;#10;&amp;#10;        # End blackout if enter is pressed&amp;#10;        if remaining_time &lt;= 1 and 'return' in keys:&amp;#10;            transition_to_main = True&amp;#10;            acquisition = False&amp;#10;            event.clearEvents()&amp;#10;            break" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;while (keyboard_tutorial) {&amp;#10;    end_keys = psychoJS.eventManager.getKeys([&quot;escape&quot;]);&amp;#10;    if (_pj.in_es6(&quot;escape&quot;, end_keys)) {&amp;#10;        sys.exit();&amp;#10;    }&amp;#10;    t = routine_clock.getTime();&amp;#10;    if (((t &gt;= schedule_manager.session_duration) &amp;&amp; ((blue_points &gt;= 10) &amp;&amp; (yellow_points &gt;= 10)))) {&amp;#10;        blackout_period = true;&amp;#10;        routine_active = false;&amp;#10;    }&amp;#10;    if (routine_active) {&amp;#10;        schedule_manager.generate_one_second_interval();&amp;#10;        in_changeover_delay = ((t - schedule_manager.last_switch_time) &lt; schedule_manager.changeover_delay);&amp;#10;        keys = psychoJS.eventManager.getKeys([&quot;space&quot;, &quot;tab&quot;]);&amp;#10;        if ((in_changeover_delay &amp;&amp; _pj.in_es6(&quot;tab&quot;, keys))) {&amp;#10;            keys.remove(&quot;tab&quot;);&amp;#10;            collect_tab_keyboard();&amp;#10;        }&amp;#10;        tab_pressed = _pj.in_es6(&quot;tab&quot;, keys);&amp;#10;        if ((_pj.in_es6(&quot;space&quot;, keys) &amp;&amp; (in_changeover_delay === false))) {&amp;#10;            [points, press_blue_earn_index, press_yellow_earn_index, blue_points, yellow_points] = handle_space_tutorial(t, schedule_manager, flash_manager, points, button_response, press_blue_earn_index, press_yellow_earn_index, blue_points, yellow_points);&amp;#10;            points_display.text = `Points: ${points}`;&amp;#10;            flash_manager.start_flash(&quot;rb&quot;, t);&amp;#10;            collect_space_keyboard();&amp;#10;        }&amp;#10;        if ((tab_pressed &amp;&amp; (! in_changeover_delay))) {&amp;#10;            switch_enabled = handle_tab_key(t, flash_manager, button_response, schedule_manager);&amp;#10;            collect_tab_keyboard();&amp;#10;        }&amp;#10;        flash_manager.update_flashes(t, green_light, red_light, button_response, button_cycle);&amp;#10;        draw_main_keyboard(psychoJS.window, green_light, red_light, button_response, button_cycle, switch_text, points_display, lights, schedule_manager);&amp;#10;    } else {&amp;#10;        if (blackout_period) {&amp;#10;            keys = psychoJS.eventManager.getKeys([&quot;return&quot;]);&amp;#10;            if ((blackout_timer === null)) {&amp;#10;                blackout_timer = new core.CountdownTimer((schedule_manager.blackout_duration + 1));&amp;#10;                blackout_start_time = core.getTime();&amp;#10;            }&amp;#10;            elapsed_time = (core.getTime() - blackout_start_time);&amp;#10;            remaining_time = Math.max(0, Number.parseInt(((schedule_manager.blackout_duration + 1) - elapsed_time)));&amp;#10;            timer_text.text = ((remaining_time &gt;= 1) ? `Time Remaining: ${remaining_time}` : &quot;Hit 'enter' to continue&quot;);&amp;#10;            draw_break(psychoJS.window, green_light_bo, red_light_bo, timer_text, points_display, response_bo, button_cycle_bo);&amp;#10;            if (((remaining_time &lt;= 1) &amp;&amp; _pj.in_es6(&quot;return&quot;, keys))) {&amp;#10;                transition_to_main = true;&amp;#10;                acquisition = false;&amp;#10;                psychoJS.eventManager.clearEvents();&amp;#10;                break;&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="points = 0;&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="#Reset points&amp;#10;points = 0" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="code_keyboard_tut" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
    <Routine name="Tutorial">
      <RoutineSettingsComponent name="Tutorial" plugin="None">
        <Param val="none" valType="str" updates="None" name="backgroundFit"/>
        <Param val="" valType="str" updates="None" name="backgroundImg"/>
        <Param val="$[0,0,0]" valType="color" updates="None" name="color"/>
        <Param val="rgb" valType="str" updates="None" name="colorSpace"/>
        <Param val="This is an explicit tutorial for PRESS-B. The Tutorial routine may be used alongside other training routines such as the &quot;Tutorial_Video&quot; and &quot;Acquisition.&quot;  " valType="str" updates="constant" name="desc"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="" valType="code" updates="None" name="durationEstim"/>
        <Param val="False" valType="code" updates="None" name="forceNonSlip"/>
        <Param val="Tutorial" valType="code" updates="None" name="name"/>
        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="tutorial" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="#Total amount of points, reset after routine&amp;#10;points = 0 &amp;#10;&amp;#10;#The following three variables&amp;#10;#are invisible to the user.&amp;#10;&amp;#10;dead_presses = 0 #Presses that don't do anything&amp;#10;&amp;#10;#How many points can be earned using each color&amp;#10;blue_points = 0&amp;#10;yellow_points = 0&amp;#10;&amp;#10;#List of objects&amp;#10;&amp;#10;#&quot;Whiteboard&quot; for instructions&amp;#10;tutorial_board = visual.Rect(win, &amp;#10;    width=1, height=0.1, &amp;#10;    fillColor=[1, 1, 1], lineColor=[0.6,0.6,0.6], &amp;#10;    fillColorSpace='rgb', lineWidth=10, pos=[0, 0.4])&amp;#10;&amp;#10;#Text instructions&amp;#10;space_instruction = visual.TextStim(win, &amp;#10;    text=&quot;Press 'SPACE' to earn points&quot;, &amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;    &amp;#10;hit_enter_prompt_blue = visual.TextStim(win,&amp;#10;    text=&quot;Press 'ENTER' to continue&quot;,&amp;#10;    height=0.04, color=[1.0000, 0.6863, -1.0000],&amp;#10;    pos=[0, 0])&amp;#10;    &amp;#10;hit_enter_prompt_yellow = visual.TextStim(win,&amp;#10;    text=&quot;Press 'ENTER' to continue&quot;,&amp;#10;    height=0.04, color=[-1.0000, -0.6863, 1.0000],&amp;#10;    pos=[0, 0])&amp;#10;&amp;#10;pre_tab_encouragement = visual.TextStim(win,&amp;#10;    text=&quot;Let's earn some more points!&quot;,&amp;#10;    height=0.04, color=[-1,-1,-1],&amp;#10;    pos=[0,0.4], opacity=1)&amp;#10;&amp;#10;points_unearnable_text = visual.TextStim(win,&amp;#10;    text=&quot;Uh-oh, you're not earning points.&quot;,&amp;#10;    height=0.04, color=[-1,-1,-1],&amp;#10;    pos=[0,0.4], opacity=1)&amp;#10;    &amp;#10;tab_instruction = visual.TextStim(win, &amp;#10;    text=&quot;Press the 'Tab' key to change the button's color.&quot;,      &amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;    &amp;#10;space_congrats_text = visual.TextStim(win, &amp;#10;    text=&quot;Congratulations, you earned a point!&quot;, &amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;&amp;#10;tab_congrats_text = visual.TextStim(win, &amp;#10;    text=&quot;Awesome, you changed the button color!&quot;, &amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;    &amp;#10;main_tutorial_text = visual.TextStim(win,&amp;#10;    text=&quot;Now that you know the basics, let's earn some points!&quot; \&amp;#10;         &quot; Switch colors to earn as many as you can.&quot;,&amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;    &amp;#10;end_tutorial_text = visual.TextStim(win, &amp;#10;    text=&quot;This is the end of the tutorial.&quot; \&amp;#10;         &quot; Use what you've learned to earn points!&quot;, &amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0.4], opacity=1)&amp;#10;    &amp;#10;end_tutorial_instruction = visual.TextStim(win, &amp;#10;    text= &quot;Hit 'enter' to continue.&quot;,&amp;#10;    height=0.04,  color=[-1,-1,-1], &amp;#10;    pos=[0, 0], opacity=1)&amp;#10;    &amp;#10;&amp;#10;#Draws objects for the tutorial.&amp;#10;&amp;#10;#Parameters&amp;#10;#----------&amp;#10;#win: obj&amp;#10;    #Psychopy window&amp;#10;#green_light_bo: object&amp;#10;    #Blacked out green_light&amp;#10;#red_light_bo: object&amp;#10;    #Blacked out red_light&amp;#10;#timer_text: object&amp;#10;    #Text for the timer, includes countdown&amp;#10;#points_display: object&amp;#10;    #Shows how many points have been earned&amp;#10;#response_bo: object&amp;#10;    #Blacked out response button&amp;#10;#button_cycle_bo:&amp;#10;    #Blacked out switch button&amp;#10;&amp;#10;def draw_tutorial(win, green_light, red_light,&amp;#10;                    button_response, button_cycle,&amp;#10;                    switch_text, points_display):&amp;#10;    green_light.draw()&amp;#10;    red_light.draw()&amp;#10;    button_response.draw()&amp;#10;    button_cycle.draw()&amp;#10;    switch_text.draw()&amp;#10;    points_display.draw()&amp;#10;    tutorial_board.draw()&amp;#10;&amp;#10;def draw_congrats(win, green_light, red_light,&amp;#10;                    button_response, switch_text,&amp;#10;                    points_display, button_cycle):&amp;#10;    green_light.draw()&amp;#10;    red_light.draw()&amp;#10;    button_response.draw()&amp;#10;    button_cycle.draw()&amp;#10;    switch_text.draw()&amp;#10;    points_display.draw()&amp;#10;    tutorial_board.draw()&amp;#10;    &amp;#10;#Summary:&amp;#10;#--------&amp;#10;#Controls space presses.&amp;#10;#Punishment is not programmed in this routine.&amp;#10;&amp;#10;#Parameters&amp;#10;#----------&amp;#10;#current_time: float&amp;#10;    #Current time in the routine&amp;#10;#green_light: object&amp;#10;    #Reinforcement light&amp;#10;#red_light: object&amp;#10;    #Punishment light&amp;#10;#button_response: object&amp;#10;    #The response button.&amp;#10;#button_cycle: object&amp;#10;    #Button that changes the response button color&amp;#10;&amp;#10;#Returns:&amp;#10;#--------&amp;#10;#points: integer&amp;#10;    #Number of points earned&amp;#10;#press_blue_earn_index: integer&amp;#10;    #Number of blue presses towards reinforcement. &amp;#10;    #Used for XR schedules&amp;#10;#press_yellow_earn_index: integer&amp;#10;    #Number of yellow presses towards reinforcement.&amp;#10;    #Used for XR schedules&amp;#10;#blue_points: integer&amp;#10;    #Number of points earned with blue.&amp;#10;    #Only called during this tutorial.&amp;#10;    #A maximum of ten can be earned.&amp;#10;#yellow_points: integer&amp;#10;    #Number of points earned with yellow&amp;#10;    #Only called during this tutorial&amp;#10;    #A maximum of ten can be earned.&amp;#10;&amp;#10;def handle_space_tutorial(t, schedule_manager, flash_manager, points,&amp;#10;                          button_response, press_blue_earn_index,&amp;#10;                          press_yellow_earn_index, blue_points,&amp;#10;                          yellow_points, sounds):&amp;#10;&amp;#10;    ding = sounds['ding'] if sounds else None&amp;#10;&amp;#10;    if (button_response.fillColor == [-1, -1, 1]).all():&amp;#10;&amp;#10;        if ((0 &lt; schedule_manager.blue_i &lt; float('inf')) or&amp;#10;            (0 &lt; schedule_manager.blue_random_i &lt; float('inf'))):&amp;#10;&amp;#10;            if t &gt;= schedule_manager.next_blue_earn_time:&amp;#10;                if blue_points &lt;= 9:&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    schedule_manager.blue_fh_index += 1&amp;#10;                    schedule_manager.next_blue_earn_time = (&amp;#10;                        schedule_manager.calculate_next_blue_earn_time(button_response)&amp;#10;                    )&amp;#10;&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;&amp;#10;                    if ding is not None:&amp;#10;                        play_sound(ding)&amp;#10;&amp;#10;        elif ((0 &lt; schedule_manager.blue_r &lt; float('inf')) or&amp;#10;              (0 &lt; schedule_manager.blue_random_r &lt; float('inf'))):&amp;#10;&amp;#10;            press_blue_earn_index += 1&amp;#10;&amp;#10;            if press_blue_earn_index &gt;= round(&amp;#10;                    schedule_manager.calculate_next_press_earn_requirement(button_response)):&amp;#10;&amp;#10;                if blue_points &lt;= 9:&amp;#10;                    blue_points += 1&amp;#10;                    points += int(schedule_manager.blue_mag)&amp;#10;                    press_blue_earn_index = 0&amp;#10;                    schedule_manager.blue_fh_index += 1&amp;#10;&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;&amp;#10;                    if ding is not None:&amp;#10;                        play_sound(ding)&amp;#10;&amp;#10;    elif (button_response.fillColor == [1, 1, -1]).all():&amp;#10;&amp;#10;        if ((0 &lt; schedule_manager.yellow_i &lt; float('inf')) or&amp;#10;            (0 &lt; schedule_manager.yellow_random_i &lt; float('inf'))):&amp;#10;&amp;#10;            if t &gt;= schedule_manager.next_yellow_earn_time:&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    schedule_manager.yellow_fh_index += 1&amp;#10;                    schedule_manager.next_yellow_earn_time = (&amp;#10;                        schedule_manager.calculate_next_yellow_earn_time(button_response)&amp;#10;                    )&amp;#10;&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;&amp;#10;                    if ding is not None:&amp;#10;                        play_sound(ding)&amp;#10;&amp;#10;        elif ((0 &lt; schedule_manager.yellow_r &lt; float('inf')) or&amp;#10;              (0 &lt; schedule_manager.yellow_random_r &lt; float('inf'))):&amp;#10;&amp;#10;            press_yellow_earn_index += 1&amp;#10;&amp;#10;            if press_yellow_earn_index &gt;= round(&amp;#10;                    schedule_manager.calculate_next_press_earn_requirement(button_response)):&amp;#10;&amp;#10;                if yellow_points &lt;= 9:&amp;#10;                    yellow_points += 1&amp;#10;                    points += int(schedule_manager.yellow_mag)&amp;#10;                    press_yellow_earn_index = 0&amp;#10;                    schedule_manager.yellow_fh_index += 1&amp;#10;&amp;#10;                    flash_manager.start_flash('gl', t)&amp;#10;&amp;#10;                    if ding is not None:&amp;#10;                        play_sound(ding)&amp;#10;&amp;#10;    return (&amp;#10;        points,&amp;#10;        press_blue_earn_index,&amp;#10;        press_yellow_earn_index,&amp;#10;        blue_points,&amp;#10;        yellow_points&amp;#10;    )" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="points = 0;&amp;#10;dead_presses = 0;&amp;#10;blue_points = 0;&amp;#10;yellow_points = 0;&amp;#10;tutorial_board = new visual.Rect(psychoJS.window, {&quot;width&quot;: 1, &quot;height&quot;: 0.1, &quot;fillColor&quot;: [1, 1, 1], &quot;lineColor&quot;: [0.6, 0.6, 0.6], &quot;fillColorSpace&quot;: &quot;rgb&quot;, &quot;lineWidth&quot;: 10, &quot;pos&quot;: [0, 0.4]});&amp;#10;space_instruction = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Press 'SPACE' to earn points&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;pos&quot;: [0, 0.4], &quot;opacity&quot;: 1});&amp;#10;hit_enter_prompt_blue = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Press 'ENTER' to continue&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [1.0, 0.6863, (- 1.0)], &quot;pos&quot;: [0, 0]});&amp;#10;hit_enter_prompt_yellow = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Press 'ENTER' to continue&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [(- 1.0), (- 0.6863), 1.0], &quot;pos&quot;: [0, 0]});&amp;#10;pre_tab_encouragement = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Let's earn some more points!&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;pos&quot;: [0, 0.4], &quot;opacity&quot;: 1});&amp;#10;points_unearnable_text = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Uh-oh, you're not earning points.&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;pos&quot;: [0, 0.4], &quot;opacity&quot;: 1});&amp;#10;tab_instruction = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Press the 'Tab' key to change the button's color.&quot;, &quot;height&quot;: 0.04, &quot;color&quot;: [(- 1), (- 1), (- 1)], &quot;pos&quot;: [0, 0.4], &quot;opacity&quot;: 1});&amp;#10;space_congrats_text = new visual.TextStim(psychoJS.window, {&quot;text&quot;: &quot;Congratulations, you earned a point!&quot;, 